@model IEnumerable<BakeryOrderSystem.Models.Customer>

<h1>Клиенты</h1>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}
<a asp-action="Create" class="btn btn-success mb-3">
    Добавить клиента
</a>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text"
               name="search"
               value="@ViewBag.Search"
               class="form-control"
               placeholder="Поиск по ФИО, телефону или email" />

        <button type="submit" class="btn btn-primary">Найти</button>

        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ФИО</th>
            <th>Телефон</th>
            <th>Email</th>
            <th>Адрес</th>
            <th>Карта</th>
            <th>Покупок</th>
            <th>Скидка</th>
            <th>Действия</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@customer.FullName</td>
                <td>@customer.Phone</td>
                <td>@customer.Email</td>
                <td>@customer.Address</td>
                <td>@customer.DiscountCardNumber</td>
                <td>@customer.PurchaseCount</td>
                <td>@customer.DiscountPercent %</td>
                <td>
                    <a asp-action="Delete"
                           asp-route-id="@customer.Id"
                           class="btn btn-danger btn-sm">
                        Удалить
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>