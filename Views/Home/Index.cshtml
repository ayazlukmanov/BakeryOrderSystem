@{
    ViewData["Title"] = "Главная";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger shadow-sm">
        @TempData["Error"]
    </div>
}

<div class="p-5 mb-4 bg-light rounded-4 shadow-sm border">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold mb-3">
            🥐 Информационная система пекарни
        </h1>

        <p class="fs-5 text-muted mb-0">
            Учет продукции, клиентов, заказов, сотрудников и складских остатков
            для предприятия малого бизнеса.
        </p>
    </div>
</div>

@if (ViewBag.ShowStatistics == true)
{
    <div class="row mb-4">

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="fs-1">🍞</div>
                    <h2 class="fw-bold">@ViewBag.ProductsCount</h2>
                    <p class="text-muted mb-0">Товаров</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="fs-1">👥</div>
                    <h2 class="fw-bold">@ViewBag.CustomersCount</h2>
                    <p class="text-muted mb-0">Клиентов</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="fs-1">🧾</div>
                    <h2 class="fw-bold">@ViewBag.OrdersCount</h2>
                    <p class="text-muted mb-0">Заказов</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="fs-1">💰</div>
                    <h2 class="fw-bold">@ViewBag.TotalRevenue ₽</h2>
                    <p class="text-muted mb-0">Выручка</p>
                </div>
            </div>
        </div>

    </div>
}

<div class="row">

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body p-4">
                <div class="fs-1 mb-3">🥖</div>
                <h3 class="fw-bold">Продукция</h3>
                <p class="text-muted">
                    Управление ассортиментом, ценами, категориями и остатками на складе.
                </p>
                <a asp-controller="Products"
                       asp-action="Index"
                       class="btn btn-primary w-100">
                    Перейти к продукции
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body p-4">
                <div class="fs-1 mb-3">👤</div>
                <h3 class="fw-bold">Клиенты</h3>
                <p class="text-muted">
                    Хранение данных клиентов, скидочных карт и количества покупок.
                </p>
                <a asp-controller="Customers"
                       asp-action="Index"
                       class="btn btn-primary w-100">
                    Перейти к клиентам
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body p-4">
                <div class="fs-1 mb-3">📦</div>
                <h3 class="fw-bold">Заказы</h3>
                <p class="text-muted">
                    Оформление заказов, выбор товаров и автоматический расчет стоимости.
                </p>
                <a asp-controller="Orders"
                       asp-action="Index"
                       class="btn btn-primary w-100">
                    Перейти к заказам
                </a>
            </div>
        </div>
    </div>

</div>