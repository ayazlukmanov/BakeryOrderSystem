@model IEnumerable<BakeryOrderSystem.Models.Category>

<h1>Категории товаров</h1>

<a asp-action="Create" class="btn btn-success mb-3">
    Добавить категорию
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Действия</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>

                <td>
                    <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger">
                        Удалить
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>