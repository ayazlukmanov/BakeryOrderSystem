@model BakeryOrderSystem.Models.Order

<h1>Добавление заказа</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label class="form-label">Клиент</label>
        <select name="CustomerId" asp-items="ViewBag.Customers" class="form-control"></select>
    </div>

    <div id="itemsContainer">

        <div class="row mb-3 order-item">
            <div class="col-md-6">
                <label class="form-label">Товар</label>
                <select name="ProductIds" class="form-control product-select">
                    @foreach (var product in ViewBag.Products)
                    {
                        <option value="@product.Id"
                                data-price="@product.Price"
                                data-stock="@product.StockQuantity">
                            @product.Name
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Количество</label>
                <input name="Quantities"
                       class="form-control quantity-input"
                       type="number"
                       min="1"
                       value="1"
                       required />
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button type="button"
                        class="btn btn-danger remove-item">
                    Удалить
                </button>
            </div>
        </div>

    </div>

    <button type="button"
            id="addItem"
            class="btn btn-success mb-3">
        Добавить ещё товар
    </button>

    <div class="alert alert-info">
        <strong>Состав заказа:</strong>
        <div id="orderSummary"></div>
        <hr />
        <div>Итого: <strong><span id="totalText">0</span> ₽</strong></div>
    </div>

    <div class="mb-3">
        <label class="form-label">Статус</label>
        <select name="Status" class="form-control">
            <option>Новый</option>
            <option>В работе</option>
            <option>Готов</option>
            <option>Выдан</option>
            <option>Отменен</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Примечание к заказу</label>
        <textarea name="Comment" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>

@section Scripts {
    <script>
        function updateOrderInfo() {
            let total = 0;
            let summaryHtml = "";

            document.querySelectorAll(".order-item").forEach(function (row) {
                const select = row.querySelector(".product-select");
                const quantityInput = row.querySelector(".quantity-input");

                const selected = select.options[select.selectedIndex];

                const name = selected.text.trim();
                const price = parseFloat(selected.getAttribute("data-price")) || 0;
                const stock = parseInt(selected.getAttribute("data-stock")) || 0;
                const quantity = parseInt(quantityInput.value) || 1;

                total += price * quantity;

                summaryHtml += `
                    <div>
                        ${name} × ${quantity} шт.
                        — ${price.toFixed(2)} ₽ за шт.
                        | Остаток: ${stock} шт.
                    </div>`;
            });

            document.getElementById("orderSummary").innerHTML = summaryHtml;
            document.getElementById("totalText").innerText = total.toFixed(2);
        }

        document.getElementById("addItem").addEventListener("click", function () {
            const container = document.getElementById("itemsContainer");
            const firstItem = container.querySelector(".order-item");
            const clone = firstItem.cloneNode(true);

            clone.querySelector(".quantity-input").value = 1;

            container.appendChild(clone);
            attachEvents();
            updateOrderInfo();
        });

        function attachEvents() {
            document.querySelectorAll(".product-select").forEach(function (select) {
                select.onchange = updateOrderInfo;
            });

            document.querySelectorAll(".quantity-input").forEach(function (input) {
                input.oninput = updateOrderInfo;
            });

            document.querySelectorAll(".remove-item").forEach(function (button) {
                button.onclick = function () {
                    const items = document.querySelectorAll(".order-item");

                    if (items.length > 1) {
                        button.closest(".order-item").remove();
                        updateOrderInfo();
                    }
                };
            });
        }

        attachEvents();
        updateOrderInfo();
    </script>
}