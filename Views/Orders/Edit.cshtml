@model BakeryOrderSystem.Models.Order

<h1>Редактирование заказа</h1>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Клиент</label>
        <input value="@Model.Customer.FullName" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Сотрудник</label>
        <input value="@Model.User.FullName" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Состав заказа</label>

        <div class="border rounded p-3 bg-light">
            @foreach (var item in Model.OrderItems)
            {
                <div>
                    @item.Product.Name × @item.Quantity шт. — @item.Price ₽
                </div>
            }
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Сумма</label>
        <input value="@Model.TotalPrice ₽" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Статус</label>
        <select name="Status" class="form-control">
            <option selected="@(Model.Status == "Новый")">Новый</option>
            <option selected="@(Model.Status == "В работе")">В работе</option>
            <option selected="@(Model.Status == "Готов")">Готов</option>
            <option selected="@(Model.Status == "Выдан")">Выдан</option>
            <option selected="@(Model.Status == "Отменен")">Отменен</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Примечание к заказу</label>
        <textarea name="Comment" class="form-control">@Model.Comment</textarea>
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>

</form>